{
  "name": "yup-intl-validator",
  "version": "1.2.0",
  "description": "A template used to create TypeScript packages.",
  "packageManager": "pnpm@10.33.0",
  "main": "./dist/esm/index.js",
  "scripts": {
    "prepare": "husky",
    "lint": "echo \"Removed\"",
    "format": "echo \"Removed\"",
    "test": "jest src --passWithNoTests",
    "test:watch": "pnpm test --watchAll",
    "build:cjs": "tsc -p ./tsconfig.json",
    "build:esm": "tsc -p ./tsconfig.module.json",
    "release": "release-it",
    "extract": "formatjs extract -- 'src/**/*.ts*' --ignore='**/*.d.ts' --out-file src/i18n/en.json --id-interpolation-pattern '[sha512:contenthash:base64:6]'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanmonier/yup-intl-validator.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "typescript",
    "package"
  ],
  "author": {
    "name": "Jordan Monier",
    "email": "pro.jordan.monier@gmail.com"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jordanmonier/yup-intl-validator/issues"
  },
  "homepage": "https://github.com/jordanmonier/yup-intl-validator#readme",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./locales/en.json": {
      "import": "./locales/en.json",
      "require": "./locales/en.json"
    },
    "./locales/fr.json": {
      "import": "./locales/fr.json",
      "require": "./locales/fr.json"
    },
    "./locales/nl.json": {
      "import": "./locales/nl.json",
      "require": "./locales/nl.json"
    }
  },
  "files": [
    "dist",
    "locales"
  ],
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@formatjs/cli": "^6.14.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/big.js": "^6.2.2",
    "@types/jest": "^30.0.0",
    "@types/lodash.mapkeys": "^4.6.9",
    "@types/lodash.orderby": "^4.6.9",
    "@types/lodash.snakecase": "^4.1.9",
    "@types/node": "^25.6.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-jordanmonier": "^5.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "release-it": "^19.2.4",
    "typescript": "^6.0.2",
    "ultracite": "7.5.6"
  },
  "dependencies": {
    "@formatjs/intl": "^4.1.5",
    "big.js": "^7.0.1",
    "dayjs": "^1.11.20",
    "lodash.mapkeys": "^4.6.0",
    "lodash.orderby": "^4.18.0",
    "lodash.snakecase": "^4.1.1",
    "validator": "^13.15.35",
    "yup": "^1.7.1"
  }
}
